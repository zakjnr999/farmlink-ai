# ----------------------------------------------------------------------------
# FarmLink AI - Backend Environment Configuration (EXAMPLE)
# Copy this file to `.env` and adjust the values. Never commit a real `.env`.
# ----------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=4000

# Database (local Postgres, Supabase, Neon, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/farmlink?schema=public

# Authentication
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=1d

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=debug

# AI extraction provider
# AI_PROVIDER one of: local | openai
AI_PROVIDER=local
AI_API_KEY=
AI_MODEL=

# Rate limiting (optional overrides)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# Seeded administrator account (development only)
ADMIN_FULL_NAME=FarmLink Administrator
ADMIN_PHONE_NUMBER=+233200000000
ADMIN_EMAIL=admin@farmlink.local
ADMIN_PASSWORD=AdminPassword123!
