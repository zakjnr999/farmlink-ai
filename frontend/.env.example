# FarmLink AI — Frontend (Next.js)
# Copy to `.env.local` for local dev. On Vercel, set these in Project → Environment Variables.

# Backend API (versioned base path /api/v1)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Production (Render)
# NEXT_PUBLIC_API_URL=https://farmlink-api-dvdx.onrender.com/api/v1

# Use in-memory demo handlers instead of the real API (local dev only).
# Must be "false" in production so login hits Render.
NEXT_PUBLIC_ENABLE_DEMO_MODE=false
