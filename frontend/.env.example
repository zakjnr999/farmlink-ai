# FarmLink AI — Frontend environment (EXAMPLE)
# Copy to `.env` (or `.env.local`) and adjust. Prefix depends on your bundler:
#   - Vite:        VITE_API_BASE_URL
#   - Next.js:     NEXT_PUBLIC_API_BASE_URL
#   - CRA:         REACT_APP_API_BASE_URL
#
# The value must point at the versioned API base path (/api/v1).

# Local backend
VITE_API_BASE_URL=http://localhost:4000/api/v1

# Production (Render) — replace with your deployed backend URL
# VITE_API_BASE_URL=https://farmlink-api.onrender.com/api/v1
